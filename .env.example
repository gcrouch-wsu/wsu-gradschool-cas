# Vercel Blob: added automatically when you create/link a Blob store to this project.
# For local dev: run `vercel link` then `vercel env pull`, or paste the token from
# Vercel → Project → Settings → Environment Variables.
BLOB_READ_WRITE_TOKEN=

# Single shared secret for admin upload + publication settings (Bearer token on /admin API).
ADMIN_SECRET=change-me-to-a-long-random-string

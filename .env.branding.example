# Optional overrides for the local WebAdMIT/Configuration Portal scraper.

# Login page opened for the one-time interactive sign-in.
BRANDING_LOGIN_URL=https://prelaunch.webadmit.org/

# Branding portal root used by the exporter.
BRANDING_BASE_URL=https://configuration.prelaunch.cas.myliaison.com/configuration/assets/index.html#!/programBranding

# Browser channel to launch. "msedge" works well on Windows without downloading browsers.
BRANDING_BROWSER_CHANNEL=msedge

# Path to the saved Playwright auth state.
BRANDING_AUTH_FILE=tools/branding/.auth/user.json

# Path to the saved navigation trail captured by "branding:record".
BRANDING_TRAIL_FILE=tools/branding/.auth/trail.json

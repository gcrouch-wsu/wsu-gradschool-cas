# Liaison CAS API defaults
GRADCAS_BASE_URL=https://api.liaisonedu.com

# Required CAS API credentials.
# Liaison docs indicate you typically need all three: API key, username, password.
GRADCAS_API_KEY=
GRADCAS_USERNAME=
GRADCAS_PASSWORD=

# Optional: if Liaison gave you a non-default auth path, override it here.
GRADCAS_TOKEN_PATH=/v1/auth/token
